# general
alias reload="source ~/.zshrc"
alias kk="claude --dangerously-skip-permissions"
alias kx="codex -s danger-full-access"

# workspace
alias ws="cd $WORKSPACE"
alias vault="cd $WORKSPACE/vault"

# repos
alias abm="cd $WORKSPACE/repos/app-backend-main"
alias abr="cd $WORKSPACE/repos/app-backend-rest"
alias wios="cd $WORKSPACE/repos/world-app-ios"
alias agentfiles="cd $WORKSPACE/repos/agentfiles"
alias dotfiles="cd $WORKSPACE/repos/dotfiles"